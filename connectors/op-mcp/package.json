{
  "name": "op-mcp-server",
  "version": "1.0.0",
  "description": "Off-Mac remote MCP server that resolves 1Password secrets via a Service Account, so claude.ai / iPhone / any surface can read op:// references without the Mac being on.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "verify": "tsx scripts/verify-sdk.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
