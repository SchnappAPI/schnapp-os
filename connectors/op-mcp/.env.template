# op-mcp connector environment. Copy to .env for local runs; set as host secrets
# in production. NEVER commit real values - only references / placeholders here.

# 1Password Service Account token. Resolves op:// references. Source of truth:
#   op://web-variables/OP_SERVICE_ACCOUNT_TOKEN/credential  (rotate via 1Password)
OP_SERVICE_ACCOUNT_TOKEN=

# Bearer gate for the /mcp endpoint. Generate a long random string:
#   openssl rand -hex 32
# Store it in 1Password too: op://web-variables/OP_MCP_BEARER/credential
OP_MCP_BEARER=

# Port the server listens on (host platforms usually inject this).
PORT=3000
