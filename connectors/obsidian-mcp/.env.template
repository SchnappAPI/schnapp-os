# obsidian-mcp host environment. Set these on the deploy host (Render etc.), never
# commit real values. Local values resolve from 1Password via op:// references.

# Bearer gate for the /mcp endpoint (a long random string). Required — the server
# refuses to start without it. Generate: `openssl rand -hex 32`.
CONNECTOR_AUTH_TOKEN=op://web-variables/obsidian-mcp/connector_auth_token

# The vault repo to serve, as owner/repo.
VAULT_REPO=SchnappAPI/obsidian-vault
VAULT_BRANCH=main

# Read access to the PRIVATE vault repo (fine-grained PAT, Contents:read on that repo only).
GITHUB_TOKEN=op://web-variables/obsidian-mcp/vault_read_token

# Where the clone lives on the host (the Dockerfile defaults this to /data/vault).
# VAULT_DIR=/data/vault

# Local development: point at an existing checkout to skip cloning, e.g.
# VAULT_DIR=/Users/schnapp/code/obsidian-vault
