RUNNER_API_KEY=op://web-variables/RUNNER_API_KEY/credential
SQL_CONNECTION_STRING=op://web-variables/SQL_CONNECTION_STRING/credential
# Web App — non-secret config (kept here for one-stop resolution; not sensitive)
HOSTNAME=op://web-variables/WEB_APP_CONFIG/hostname
NODE_ENV=op://web-variables/WEB_APP_CONFIG/node_env
PORT_PROD=op://web-variables/WEB_APP_CONFIG/port_prod
