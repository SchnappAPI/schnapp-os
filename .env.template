RUNNER_URL_DEV=op://web-variables/WEB_APP_CONFIG/runner_url_dev


# ── Webshare Proxy (NBA scraping)
# item name has a space → ref quoted per 1Password syntax rule
WEBSHARE_HOST="op://web-variables/Webshare Proxy/host"
WEBSHARE_PORT="op://web-variables/Webshare Proxy/port"
WEBSHARE_USERNAME="op://web-variables/Webshare Proxy/username"
WEBSHARE_PASSWORD="op://web-variables/Webshare Proxy/password"
# NBA ETL reads the full proxy URL under the name NBA_PROXY_URL:
NBA_PROXY_URL="op://web-variables/Webshare Proxy/proxy_url"


# ── Cloudflare
# Tunnel (cloudflared on the Mac)
# item name has a space → refs quoted per 1Password syntax rule
CLOUDFLARE_TUNNEL_ID="op://web-variables/Cloudflare Tunnel/tunnel_id"
CLOUDFLARE_ACCOUNT_TAG="op://web-variables/Cloudflare Tunnel/account_tag"
CLOUDFLARE_TUNNEL_SECRET="op://web-variables/Cloudflare Tunnel/tunnel_secret"
CLOUDFLARE_ARGO_TOKEN="op://web-variables/Cloudflare Tunnel/argo_token"
CLOUDFLARE_CONFIG_PATH="op://web-variables/Cloudflare Tunnel/config_path"
CLOUDFLARE_CREDENTIALS_PATH="op://web-variables/Cloudflare Tunnel/credentials_path"
# Account API token (broad scope) for the Cloudflare MCP connector / API, plus its
# auto-derived R2 S3 credentials (same token). Separate item from `Cloudflare Tunnel` above.
