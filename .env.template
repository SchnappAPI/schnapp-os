# Env template — references only, never values. Copy to .env (gitignored) and resolve
# with: `op run --env-file=.env -- <cmd>` or `op inject`. See credentials-map.md and
# the secrets-as-references rule. New env vars are added here as op:// URIs, never literals.

# Bootstrap: the 1Password Service Account token itself. Set this directly in the
# surface's env (shell profile / host secret) from the 1Password item; it is what
# resolves every other op:// reference below, so it cannot be an op:// lookup at bootstrap.
OP_SERVICE_ACCOUNT_TOKEN=

# Examples — confirm the exact field label in 1Password before relying on these
# (field labels in `web-variables` are not always the category default; see credentials-map.md):
# GITHUB_PAT=op://web-variables/GITHUB_PAT/<field>
# DATABASE_PASSWORD=op://web-variables/Database/<field>
# CLOUDFLARE_TUNNEL_TOKEN=op://web-variables/Cloudflare Tunnel/<field>
