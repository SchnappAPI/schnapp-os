<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.schnapp.memory-consolidation</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO__/scripts/learning-worker.sh</string>
    </array>

    <!-- Run from the repo root so the worker's own REPO_ROOT and relative paths resolve. -->
    <key>WorkingDirectory</key>
    <string>__REPO__</string>

    <!-- launchd's default PATH is only /usr/bin:/bin:/usr/sbin:/sbin, so `claude` (in
         /usr/local/bin) and homebrew git/gh would not be found and the live run would
         silently no-op. Prepend the dirs the worker + gate need. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <!-- op:// reference to the Claude OAuth token (a reference, not the secret). The worker
             resolves it via `op read` at runtime so the headless run authenticates despite
             launchd not reaching the login Keychain. Substituted at install (see README). -->
        <key>LEARNING_CLAUDE_TOKEN_REF</key>
        <string>__CLAUDE_TOKEN_REF__</string>
    </dict>

    <!-- Run the moment a capture is enqueued (the queue file changes) AND every 30 min as a backstop,
         so a correction is consolidated within seconds of being captured - no reliance on a nightly
         time or a manual SessionEnd trigger you might forget. Empty-queue runs exit immediately
         (near-free). The worker drains the queue on completion, which re-fires WatchPaths once → an
         instant no-op. (The queue file must exist for the watch; the install `touch`es it - see README.) -->
    <key>WatchPaths</key>
    <array>
        <string>__REPO__/scheduled-tasks/.learning-queue.tsv</string>
    </array>
    <key>StartInterval</key>
    <integer>1800</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/schnapp-os/memory-consolidation.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/schnapp-os/memory-consolidation.err.log</string>
</dict>
</plist>
