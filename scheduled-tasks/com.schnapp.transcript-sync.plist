<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.schnapp.transcript-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO__/scripts/transcript-sync.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO__</string>

    <!-- launchd's default PATH misses homebrew git; push uses the Mac's ssh key
         (same as vault-autocommit), so PATH is the only env needed. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Every 15 minutes: incremental (mtime/size state), so an idle Mac is a
         near-no-op. Interval, not WatchPaths: transcripts append on every tool
         call; watching them would fire constantly for no gain. -->
    <key>StartInterval</key>
    <integer>900</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/schnapp-os/transcript-sync.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/schnapp-os/transcript-sync.log</string>
</dict>
</plist>
